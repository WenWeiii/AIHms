rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition (Phase 3)
    function isSignedIn() { return request.auth != null; }
    // Relaxed for AI Studio environment unless strictly required by user
    function isEmailVerified() { return isSignedIn(); } 
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Path variable hardening
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Admin lookup
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "shumww1@gmail.com" || 
        request.auth.token.email == "ongyh123@gmail.com"
      );
    }

    // Caregiver sync logic
    function isAssignedCaregiver(patientId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(patientId)).data.get('caregiverIds', []).hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedPatientId', '') == patientId
      );
    }

    function canAccessUserData(userId) {
      return isOwner(userId) || isAdmin() || isAssignedCaregiver(userId);
    }

    // --- Validation Blueprints (Pillar 2) ---

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['patient', 'caregiver', 'admin'] &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128);
    }

    function isValidHealthLog(data, userId) {
      return data.userId == userId &&
             data.timestamp is string &&
             data.triageZone in ['Red', 'Yellow', 'Green', 'None'] &&
             (data.get('heartRate', 0) is number) &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 2048);
    }

    function isValidAppointment(data, userId) {
      return data.userId == userId &&
             data.title is string && data.title.size() <= 256 &&
             data.status in ['scheduled', 'pending', 'cancelled'];
    }

    function isValidChatMessage(data) {
      return data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 5000;
    }

    function isValidCommunityPost(data) {
      return data.authorId == request.auth.uid &&
             data.type in ['event', 'tip', 'milestone'] &&
             data.title is string && data.title.size() <= 256 &&
             data.content is string && data.content.size() <= 10000;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn(); // Allow discovery
      allow list: if isSignedIn(); // Allow "Recommended Users" discovery
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (
        ((isOwner(userId) || isAssignedCaregiver(userId)) && isValidUser(incoming()) && (
          // Ensure immutable fields
          incoming().uid == existing().uid &&
          incoming().email == existing().email &&
          incoming().role == existing().role && (
            // Action: Owner Update
            (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly([
              'displayName', 'photoURL', 'language', 'hasCompletedOnboarding', 'bio', 
              'bloodType', 'allergies', 'gender', 'houseAddress', 'dob', 'conditions', 'medications', 'icNumber',
              'fullName', 'phoneNumber', 'relationship', 'agencyId', 'licenseNumber',
              'wearableConnected', 'wearableType', 'wearableToken', 'wearableSyncedAt', 
              'latestVitals', 'followingCount', 'followerCount', 
              'inviteToken', 'inviteTokenExpiresAt', 'mainCaregiverId', 'assignedPatientId', 'caregiverIds',
              'updatedAt'
            ])) ||
            // Action: Caregiver updating Patient Info
            (isAssignedCaregiver(userId) && existing().role == 'patient' && incoming().diff(existing()).affectedKeys().hasOnly(['bloodType', 'allergies', 'updatedAt']))
          )
        )) || 
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['followerCount'])) ||
        isAdmin()
      );

      match /healthLogs/{logId} {
        allow read: if canAccessUserData(userId);
        allow create: if canAccessUserData(userId) && isValidHealthLog(incoming(), userId) && isValidId(logId);
        allow update: if canAccessUserData(userId) && isValidHealthLog(incoming(), userId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'mood', 'triageZone', 'analysis', 'updatedAt'])
        );
        allow delete: if isAdmin();
      }

      match /appointments/{apptId} {
        allow read: if canAccessUserData(userId);
        allow create: if canAccessUserData(userId) && isValidAppointment(incoming(), userId) && isValidId(apptId);
        allow update: if canAccessUserData(userId) && isValidAppointment(incoming(), userId) && (
          // Terminal State Locking (Pillar 4)
          existing().status != 'cancelled' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'reminderEnabled', 'updatedAt'])
        );
        allow delete: if isAdmin();
      }

      match /chatHistory/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatMessage(incoming()) && isValidId(messageId);
        // Messages are usually immutable
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /trustedContacts/{contactId} {
        allow read: if canAccessUserData(userId);
        allow write: if isOwner(userId) && isValidId(contactId);
      }

      match /joinedCircles/{circleId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /likes/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /rsvps/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /bookmarks/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /following/{targetId} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId) || isOwner(userId);
      }
    }

    match /communityPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidCommunityPost(incoming()) && isValidId(postId);
      allow update: if (isOwner(existing().authorId) && isValidCommunityPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'location', 'eventDate', 'updatedAt'])
      )) || (
        // Allow likes/rsvps increment (Pillar 7 - usually better via server but here for simplicity)
        isSignedIn() && incoming().diff(existing()).affectedKeys().hasAny(['likes', 'attendees'])
      ) || isAdmin();
      allow delete: if isOwner(existing().authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isEmailVerified() && incoming().authorId == request.auth.uid && isValidId(commentId);
        allow delete: if isOwner(existing().authorId) || isAdmin();
      }
    }

    match /circles/{circleId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && incoming().createdBy == request.auth.uid && isValidId(circleId);
      allow update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      function isMember() {
        return isSignedIn() && conversationId.split('_').hasAll([request.auth.uid]);
      }
      allow read: if isMember();
      allow create: if isMember();
      
      match /messages/{messageId} {
        allow read: if isMember();
        allow create: if isMember() && incoming().senderId == request.auth.uid && isValidId(messageId);
      }
    }

    // Default catch-all (Pillar 6/8)
    match /{path=**}/healthLogs/{logId} {
      allow list: if isAdmin(); // Only admins can list across all users
    }
    match /{path=**}/appointments/{apptId} {
      allow list: if isAdmin(); // Only admins can list across all users
    }
  }
}
